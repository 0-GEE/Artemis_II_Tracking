// -----  --------------- -----------------

// Note:  setInterval() from javascript doesn't work in Stellarium API -- using core.wait() in a loop seems to work though:


// ---------   Infinite Loop ------------------------
// checks current time - if it has changed, then update the position, otherwise just wait/sleep for a bit and repeat

// Get initial time
let lastTime = core.getJDay();

// TODO:   check for null values -- intial and in loop!!!! ?


// Set initial location
var orionRa = lookupTableLinearInterpolation(raLookupTable, lastTime);
var orionDec = lookupTableLinearInterpolation(decLookupTable, lastTime);
// add custom object with new location
if( orionRa != null && orionDec != null)
{
	CustomObjectMgr.addCustomObject("Artemis II", raHoursToHmsString(orionRa),  degToDmsString(orionDec)  , true);
}

// J2000 - doesn't work only used for pointing vector, assumes infinitely far away object - which is not the case here
// Test object added with J2000 coordinates (in AU) -- not sure if only supposed to use unit vector.... hoping this may work for any location
//var orionX = lookupTableLinearInterpolation(xLookupTable, lastTime);
//var orionY = lookupTableLinearInterpolation(yLookupTable, lastTime);
//var orionZ = lookupTableLinearInterpolation(zLookupTable, lastTime);
//var positionXYZ = core.vec3d(orionX,orionY,orionZ); // Example  vector
//if( orionX != null && orionY != null && orionZ != null)
//{
//	CustomObjectMgr.addCustomObject("J2000", positionXYZ, true);
//}

var i = 0;
//while (i < 500) // to limit length of script run
while (true)  // run forever
{
    // 
    //core.debug("Running action");

    // get current time
    const currentTime = core.getJDay(); 
    
    if (currentTime !== lastTime) 
    {  
	
	//core.debug("Time changed! New Orion Position.");
	

        // NOTE - need to remove old one
        CustomObjectMgr.removeCustomObject("Artemis II");
        //CustomObjectMgr.removeCustomObject("J2000");  // J2000 version (for now)


        // add updated location - TEST
        //CustomObjectMgr.addCustomObject("Artemis II", "11h19m07.7s",  degToDmsString(decTest+i/60.0 )  , true);
	
	// calculate new location
	orionRa = lookupTableLinearInterpolation(raLookupTable, currentTime);
	orionDec = lookupTableLinearInterpolation(decLookupTable, currentTime);

	// J2000 version (for now) -- DOESN'T WORK - only for infinitely far objects
	//orionX = lookupTableLinearInterpolation(xLookupTable, currentTime);
	//orionY = lookupTableLinearInterpolation(yLookupTable, currentTime);
	//orionZ = lookupTableLinearInterpolation(zLookupTable, currentTime);


	// add custom object with new location - if data is not null (within time range)
	if( orionRa != null && orionDec != null)
	{
		CustomObjectMgr.addCustomObject("Artemis II", raHoursToHmsString(orionRa),  degToDmsString(orionDec)  , true);
		
		// J2000 for now
		//positionXYZ = core.vec3d(orionX,orionY,orionZ);
		//CustomObjectMgr.addCustomObject("J2000", positionXYZ, true);

	}

        // update/save time to lastTime
        lastTime = currentTime; // save time to

    } // if time changed
     

    core.wait(0.25); // Wait  [seconds] before next iteration

    i++; // increment

} // while - check for changes to the time

core.debug("Bye!");
