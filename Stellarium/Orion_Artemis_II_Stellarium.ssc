// This version is RA/DEC J2000.0   --  I beleive this can have spaces in it as well and it still works
//CustomObjectMgr.addCustomObject("Artemis II", "11h19m07.7s", "+13d23m18.2s", true);
//var decTest = 13.3883888889;
//CustomObjectMgr.addCustomObject("Artemis II", "11h19m07.7s",  degToDmsString(decTest)  , true);
// -----------------


